# ── PostgreSQL Local Connection ───────────────────────────────
# Fill these in with your local pgAdmin / PostgreSQL credentials
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Innovatics_Retail
DB_USER=postgres
DB_PASSWORD=1234567

# ── Scraper Behaviour ─────────────────────────────────────────
SCRAPER_HEADLESS=True
SCRAPER_SLOW_MO=800
SCRAPER_TIMEOUT=30000
SCRAPER_MAX_RETRIES=3
SCRAPER_DELAY_MIN=2.0
SCRAPER_DELAY_MAX=5.0

# ── POC Metadata ──────────────────────────────────────────────
DATA_LABEL=demonstration_data
POC_RUN_ID=poc_run_001
